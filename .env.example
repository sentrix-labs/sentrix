# Sentrix Node Environment
# Copy to .env and fill in real values

# API authentication (POST endpoints)
SENTRIX_API_KEY=your_api_key_here

# Validator private key (node produces blocks if set)
SENTRIX_VALIDATOR_KEY=your_validator_private_key_here

# Admin key (validator management)
SENTRIX_ADMIN_KEY=your_admin_private_key_here

# CORS origin for cross-origin browser requests
# M-06 FIX: Not set or empty → restrictive default (no cross-origin allowed)
# For local dev: SENTRIX_CORS_ORIGIN=*
# For production: use comma-separated specific origins (note: only single origin supported currently)
# Example: SENTRIX_CORS_ORIGIN=https://sentrixscan.sentriscloud.com
SENTRIX_CORS_ORIGIN=
