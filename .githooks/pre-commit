#!/usr/bin/env bash
# Sentrix pre-commit hook — block commits that contain known secrets.
#
# Activation (run once per clone):
#   git config core.hooksPath .githooks
#
# This hook scans the *staged* content (not the working tree, not history) so
# you can keep local files like .env outside the index without trouble. It
# fails the commit on the first match and prints exactly what triggered it.
#
# Bypass (only for false positives, document why):
#   git commit --no-verify
# CI also runs an equivalent scan, so a --no-verify commit will still be
# caught at PR time.

set -e

# Bash 3 compatible (no associative arrays — works on macOS default bash).
PATTERNS_NAME=(
  "secp256k1 private key (64-hex)"
  "leaked Founder/EarlyValidator key (specific)"
  "VPS1 IP"
  "VPS2 IP"
  "VPS3 IP"
  "SSH user sentriscloud@"
  "SSH user VPS2Sentrix@"
  "Hardcoded ADMIN_KEY assignment"
  "Hardcoded private_key= assignment"
  "Hardcoded secret_key= assignment"
  "Personal Gmail (sentriscloud@gmail.com)"
  "Known wallet address (founder/validators)"
  "Generic 0x + 40 hex address (use whitelist allow-paths if legitimate)"
)
PATTERNS_REGEX=(
  "\\b[0-9a-fA-F]{64}\\b"
  "(1972cc6156b00041|f33c92c49be373e9)"
  "\\b103\\.150\\.92\\.25\\b"
  "\\b103\\.175\\.219\\.233\\b"
  "\\b46\\.250\\.229\\.238\\b"
  "sentriscloud@[0-9]"
  "VPS2Sentrix@"
  "ADMIN_KEY[[:space:]]*=[[:space:]]*[\"']?[0-9a-fA-F]{40,}"
  "private_key[[:space:]]*=[[:space:]]*[\"']?[0-9a-fA-F]{40,}"
  "secret_key[[:space:]]*=[[:space:]]*[\"']?[0-9a-fA-F]{40,}"
  "sentriscloud@gmail\\.com"
  "0x(4f3319a747fd564136209cd5d9e7d1a1e4d142be|252f8cfed5acfa9d00d99a65e2ac91f395a35d78|328d56b8174697ef6c9e40e19b7663797e16fa47|a7fc67af1ba0c664d859f4c1bcd2eb1f7211f112|682126f5f973bddda2c92fb0dfce8a4ba275c99b|4f9988506a5e9d7a4b0eae15e5b71a02834d6c0f|245785f409d853bb04d6910a3a0f78df7cbd184c|4e9b3c4901ce6f5f60e3fb97ab97b3352675f36b|d2116bc9767249ee2394840ee6bb02896009fb07)"
  "\\b0x[0-9a-fA-F]{40}\\b"
)

# Skip these paths from the broad 64-hex check — they are legitimate hashes:
# block_hash, state_root, code_hash, EMPTY_*, KECCAK_EMPTY constants, etc.
HEX_ALLOW_PATHS=(
  "^src/core/account\\.rs$"          # EMPTY_CODE_HASH constant
  "^src/.*test.*\\.rs$"               # all test modules (test vectors)
  "^tests/"                            # integration tests
  "^Cargo\\.lock$"                    # dependency hashes
  "^tools/.*/Cargo\\.lock$"           # standalone-tool lockfiles carry the same hash shape
  "^docs/.*\\.md$"                    # docs may show example hashes
  "^CHANGELOG\\.md$"                  # commit hashes
  "^benchmark/.*\\.py$"               # benchmark scripts (after env-var migration)
)

# Skip these paths from the broad "0x + 40 hex" address check — they are
# legitimate places to mention addresses (genesis constants, audit log,
# the hook itself, the gitignore).
ADDR_ALLOW_PATHS=(
  "^\\.gitignore$"
  "^\\.githooks/pre-commit$"
  "^\\.github/"                       # CI workflows may reference docs paths
  "^CHANGELOG\\.md$"                  # historical / audit trail mentions
  "^WHITEPAPER\\.md$"                 # example addresses + contact email
  "^CONTRIBUTING\\.md$"               # may reference example addresses
  "^src/core/"                         # re-export layer references genesis constants
  "^src/api/"                          # API module tests reference genesis addresses via constants
  "^src/.*test.*\\.rs$"               # tests use generated random addrs
  "^crates/sentrix-core/src/"          # core crate: genesis constants, test addresses
  "^crates/sentrix-primitives/src/"    # primitives: TOKEN_OP_ADDRESS/STAKING_ADDRESS constants + test addrs
  "^crates/sentrix-trie/src/"          # trie crate: test address_to_key patterns
  "^crates/sentrix-rpc/src/"           # RPC crate: route tests with addresses
  "^crates/sentrix-rpc-types/src/"     # RPC type-conversion helpers: tests use v1 founder addr as fixed vector
  "^crates/sentrix-evm/src/"           # EVM crate: sentri→wei conversion tests use fixed addrs
  "^genesis/"                          # externalised genesis TOML (validators + premine allocations)
  "^tests/"                            # integration tests
  "^docs/.*\\.md$"                    # docs may show example addresses
  "^benchmark/.*\\.py$"               # benchmark scripts use env var by default
  "^tools/"                            # standalone tools (bench-tps etc.) — placeholder addresses
)

red()   { printf '\033[31m%s\033[0m' "$*"; }
green() { printf '\033[32m%s\033[0m' "$*"; }
yellow(){ printf '\033[33m%s\033[0m' "$*"; }

# Get the list of staged files (added or modified, no deletions).
mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=AM)
if [ ${#STAGED[@]} -eq 0 ]; then
  exit 0
fi

# .gitignore + this hook + .githooks/ itself are always allowed (text rules).
filter_out_internal() {
  local f
  for f in "$@"; do
    case "$f" in
      .gitignore|.githooks/*) ;;
      *) printf '%s\n' "$f" ;;
    esac
  done
}
mapfile -t SCAN < <(filter_out_internal "${STAGED[@]}")

# Helper: is path $1 in the allow-list array $2?
path_in_allowlist() {
  local path="$1"
  shift
  local allow
  for allow in "$@"; do
    if printf '%s' "$path" | grep -qE "$allow"; then
      return 0
    fi
  done
  return 1
}

violations=0
for f in "${SCAN[@]}"; do
  [ -f "$f" ] || continue

  # Read the staged blob (not the working tree — handles partial-stage cases).
  staged_content=$(git show ":$f" 2>/dev/null) || continue

  for i in "${!PATTERNS_REGEX[@]}"; do
    name="${PATTERNS_NAME[$i]}"
    regex="${PATTERNS_REGEX[$i]}"

    # Pattern 0: broad 64-hex — skip allow-listed paths.
    if [ "$i" = "0" ]; then
      if path_in_allowlist "$f" "${HEX_ALLOW_PATHS[@]}"; then
        continue
      fi
    fi

    # Pattern 10: personal gmail — allowed in WHITEPAPER (contact section)
    if [ "$i" = "10" ]; then
      if path_in_allowlist "$f" "${ADDR_ALLOW_PATHS[@]}"; then
        continue
      fi
    fi

    # Patterns 11 (known addresses) and 12 (generic 0x+40hex) share an
    # allow-list — both legitimately appear in genesis constants
    # (blockchain.rs), historical changelog entries, the hook itself,
    # tests using random keypairs, etc.
    if [ "$i" = "11" ] || [ "$i" = "12" ]; then
      if path_in_allowlist "$f" "${ADDR_ALLOW_PATHS[@]}"; then
        continue
      fi
    fi

    if hits=$(printf '%s\n' "$staged_content" | grep -nE "$regex" | head -3); then
      if [ -n "$hits" ]; then
        if [ "$violations" = "0" ]; then
          echo
          red "  ╔══════════════════════════════════════════════════════════╗"; echo
          red "  ║  PRE-COMMIT BLOCKED: secret(s) detected in staged content "; echo
          red "  ╚══════════════════════════════════════════════════════════╝"; echo
        fi
        echo
        yellow "  $f"; echo
        echo "    rule: $name"
        printf '%s\n' "$hits" | sed 's/^/      /'
        violations=$((violations + 1))
      fi
    fi
  done
done

if [ "$violations" -gt 0 ]; then
  echo
  red "  $violations violation(s) found — commit blocked."; echo
  echo "  Fix the file(s) above, re-stage with 'git add', then commit again."
  echo "  Bypass (only for confirmed false positive, document why):"
  echo "    git commit --no-verify"
  echo
  exit 1
fi

green "  pre-commit: no secrets detected ($(printf '%d' "${#SCAN[@]}") staged file(s) scanned)"; echo
exit 0
