# Build artifacts
/target/

# Chain data & wallets — NEVER commit
/data/
*.db
*.db-*

# Wallet files — contains private keys
**/wallets/
**/genesis_wallets*.json
**/node_keys/

# Keystore files
*.keystore
*.keystore.json

# Private keys / secrets
*.pem
*.key
*.secret
*.env
*.env.*
.env.local
# Allow .env.example (safe template, no real values)
!.env.example

# Build helper scripts (local dev only)
*.bat
blog.txt
tlog.txt

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.bak
*.backup
*.old

# Docker data / runtime
docker-compose.override.yml
*.tar
*.tar.gz

# Logs
*.log
logs/

# Crash dumps / core dumps (root-level only — avoids matching src/core/)
/core
/core.*
*.dmp

# Rust-specific
*.rlib
*.rmeta

# Duplicate env template (keep .env.example only)
env.example

# Test artifacts
/test-ledger/

# Rust editor backup files
**/*.rs.bk

# Log files
log-*.txt
