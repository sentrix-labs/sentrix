# ============================================================
# Sentrix Chain — strict .gitignore
# Backed up by .githooks/pre-commit which scans staged content.
# ============================================================

# ── Build artifacts ─────────────────────────────────────────
/target/
/tools/*/target/
*.rlib
*.rmeta

# ── Chain data & DBs (NEVER commit) ─────────────────────────
/data/
*.db
*.db-*
/test-ledger/

# ── Wallets, keys, secrets (NEVER commit) ───────────────────
# Keystore files (encrypted, but still sensitive)
*.keystore
*.keystore.json

# Raw key material
*.key
*.pem
*.p12
*.pfx
*.enc
*.credentials

# Wallet JSON (broad — any file with "wallet" in name)
*wallet*.json
**/wallets/
**/genesis_wallets*
**/node_keys/

# Anything literally named "private" or "secret" (no extension restriction)
*private*
*secret*
*.secret

# Env files (allow .env.example only)
.env
.env.*
*.env
*.env.*
!.env.example

# ── Build helper / dev-only scripts ─────────────────────────
*.bat
blog.txt
tlog.txt

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Backup, temp, logs ───────────────────────────────────────
*.bak
*.backup
*.old
*.tmp
tmp/
*.log
log-*.txt
logs/

# ── Docker runtime ───────────────────────────────────────────
docker-compose.override.yml
*.tar
*.tar.gz

# ── Crash dumps (root-level only — avoids matching src/core/) ─
/core
/core.*
*.dmp

# ── Duplicate env template (keep .env.example only) ─────────
env.example

# ── Python bytecode (benchmark/ scripts) ────────────────────
__pycache__/
*.pyc
*.pyo

# ── Rust editor backup files ────────────────────────────────
**/*.rs.bk

.claude/
